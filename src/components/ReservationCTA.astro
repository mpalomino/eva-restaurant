---
const phone = '612 192 2716';
---

<section class="py-20 md:py-28 bg-green relative overflow-hidden">
  <!-- Decorative background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px]">
      <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.3" class="w-full h-full text-white">
        <circle cx="50" cy="45" r="28" />
        <path d="M50 73 L50 95" />
        <path d="M35 35 C35 25, 50 15, 50 30 C50 15, 65 25, 65 35 C65 25, 75 35, 65 45 C75 40, 70 55, 55 50 C65 55, 55 65, 50 55 C45 65, 35 55, 45 50 C30 55, 25 40, 35 45 C25 35, 35 25, 35 35Z" />
      </svg>
    </div>
  </div>

  <div class="relative z-10 max-w-3xl mx-auto px-4 text-center">
    <h2 class="heading text-4xl md:text-5xl text-white mb-4" data-i18n="cta.title">
      Reserva Tu Mesa
    </h2>
    <p class="accent text-xl text-white/70 mb-10" data-i18n="cta.subtitle">
      Celebra tu manana con nosotros
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={`tel:+52${phone.replace(/\s/g, '')}`}
        class="flex items-center gap-3 bg-white text-green px-8 py-4 rounded text-lg font-medium hover:bg-cream transition-colors duration-300 min-w-[200px] justify-center"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span data-i18n="cta.call">Llamar</span>
      </a>
      <a
        href={`https://wa.me/52${phone.replace(/\s/g, '')}?text=Hola%2C%20me%20gustaria%20hacer%20una%20reservacion%20en%20Eva's%20Restaurante.`}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 bg-white/10 border border-white/30 text-white px-8 py-4 rounded text-lg font-medium hover:bg-white/20 transition-colors duration-300 min-w-[200px] justify-center"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a8 8 0 01-4.243-1.214l-.295-.175-2.462.731.731-2.462-.175-.295A8 8 0 1112 20z"/>
        </svg>
        <span>WhatsApp</span>
      </a>
    </div>

    <p class="text-white/50 mt-6 text-sm">{phone}</p>
  </div>
</section>
