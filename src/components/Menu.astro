---

<section id="menu" class="py-20 md:py-32 bg-white">
  <div class="max-w-6xl mx-auto px-4 md:px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="accent text-terra text-lg tracking-[0.2em] uppercase mb-3">Eva's Restaurante</p>
      <h2 class="heading text-5xl md:text-6xl text-black" data-i18n="menu.title">Menu</h2>
    </div>

    <!-- Category tabs -->
    <div class="mb-12">
      <div id="menu-tabs" class="flex flex-wrap justify-center gap-2 md:gap-3">
        {categories.map((cat, i) => (
          <button
            class:list={[
              'menu-tab px-3 py-1.5 text-xs md:px-4 md:py-2 md:text-sm tracking-wide rounded-full border transition-all duration-300',
              i === 0 ? 'bg-green text-white border-green' : 'text-gray border-gray-light hover:border-green hover:text-green',
            ]}
            data-target={cat.id}
          >
            {cat.name}
          </button>
        ))}
      </div>
    </div>

    <!-- Category sections -->
    {categories.map((cat, i) => (
      <div
        class:list={['menu-section', i === 0 ? 'block' : 'hidden']}
        id={`menu-${cat.id}`}
      >
        <div class="mb-8">
          <h3 class="accent text-3xl md:text-4xl text-green mb-2">{cat.name}</h3>
          {cat.subtitle && (
            <p class="text-gray text-sm italic max-w-2xl">{cat.subtitle}</p>
          )}
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
          {cat.items.map((item: any) => (
            <div class:list={[
              'flex justify-between items-start gap-4 pb-4 border-b border-gray-light/50',
              item.featured && 'bg-cream/50 -mx-3 px-3 py-3 rounded border-green/30',
            ]}>
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <span class:list={['font-medium text-black', item.featured && 'text-green font-bold']}>
                    {item.name}
                  </span>
                  {item.featured && (
                    <span class="text-xs bg-terra text-white px-2 py-0.5 rounded uppercase tracking-wider">Signature</span>
                  )}
                </div>
                {item.desc && (
                  <p class="text-gray text-sm italic mt-1">{item.desc}</p>
                )}
              </div>
              <span class="text-green font-medium whitespace-nowrap">${item.price}</span>
            </div>
          ))}
        </div>

        {cat.id === 'chilaquiles' && (
          <div class="mt-8 bg-green/10 border border-green/20 rounded-lg p-6 max-w-md">
            <h4 class="font-bold text-green mb-3 uppercase text-sm tracking-wider" data-i18n="menu.salsas.title">Salsas Disponibles</h4>
            <ul class="space-y-1">
              {salsas.map((salsa) => (
                <li class="text-gray text-sm flex items-center gap-2">
                  <span class="w-1.5 h-1.5 bg-terra rounded-full"></span>
                  {salsa}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    ))}

    <!-- Note -->
    <div class="mt-12 text-center">
      <p class="text-gray text-sm italic" data-i18n="menu.note">
        No tenemos medias ordenes. Cualquier cambio puede generar costo extra.
      </p>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  const tabs = document.querySelectorAll('.menu-tab');
  const sections = document.querySelectorAll('.menu-section');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-target');

      tabs.forEach((t) => {
        t.classList.remove('bg-green', 'text-white', 'border-green');
        t.classList.add('text-gray', 'border-gray-light');
      });
      tab.classList.add('bg-green', 'text-white', 'border-green');
      tab.classList.remove('text-gray', 'border-gray-light');

      sections.forEach((s) => {
        s.classList.add('hidden');
        s.classList.remove('block');
      });
      const targetSection = document.getElementById(`menu-${target}`);
      targetSection?.classList.remove('hidden');
      targetSection?.classList.add('block');
    });
  });
</script>
