---
---

<section id="hero" class="relative h-screen flex items-center justify-center overflow-hidden">
  <!-- Background placeholder -->
  <div class="absolute inset-0 bg-black">
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/60"></div>
    <!-- Placeholder image — replace with real hero photo -->
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1484723091739-30a097e8f929?w=1920&q=80')] bg-cover bg-center"></div>
    <div class="absolute inset-0 bg-black/40"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4">
    <!-- Carnation mark placeholder -->
    <div class="mb-6 inline-block">
      <svg class="w-20 h-20 mx-auto text-white/80" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <circle cx="50" cy="45" r="28" />
        <path d="M50 73 L50 90" />
        <path d="M35 35 C35 25, 50 15, 50 30 C50 15, 65 25, 65 35 C65 25, 75 35, 65 45 C75 40, 70 55, 55 50 C65 55, 55 65, 50 55 C45 65, 35 55, 45 50 C30 55, 25 40, 35 45 C25 35, 35 25, 35 35Z" />
      </svg>
    </div>

    <h1 class="heading text-5xl md:text-7xl lg:text-8xl text-white mb-4 tracking-wide">
      Eva's
    </h1>
    <p class="accent text-xl md:text-2xl text-white/70 tracking-[0.3em] uppercase mb-8">
      Restaurante
    </p>
    <p class="text-lg md:text-xl text-white/80 max-w-md mx-auto font-light" data-i18n="hero.tagline">
      Donde cada manana es una celebracion
    </p>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
