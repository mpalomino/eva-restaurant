---
const address = '2155 Miguel L de Legaspi/Javier Mina, Gral Manuel M. Dieguez, Los Olivos, 23040 La Paz, B.C.S.';
const phone = '612 192 2716';
const mapQuery = encodeURIComponent('Eva\'s Restaurante, Miguel L de Legaspi, La Paz, BCS, Mexico');
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;
---

<section id="location" class="py-20 md:py-32 bg-cream-dark">
  <div class="max-w-6xl mx-auto px-4 md:px-6">
    <div class="text-center mb-16">
      <p class="accent text-terra text-lg tracking-[0.2em] uppercase mb-3">Eva's Restaurante</p>
      <h2 class="heading text-4xl md:text-5xl text-black" data-i18n="location.title">
        Visitanos
      </h2>
    </div>

    <!-- Info cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 md:gap-8 mb-12">
      <div class="bg-white rounded-lg p-6 text-center shadow-sm">
        <div class="w-10 h-10 mx-auto mb-4 text-green">
          <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <h3 class="accent text-lg text-green mb-2 uppercase tracking-wider" data-i18n="location.address">Direccion</h3>
        <p class="text-gray text-sm leading-relaxed">{address}</p>
      </div>

      <div class="bg-white rounded-lg p-6 text-center shadow-sm">
        <div class="w-10 h-10 mx-auto mb-4 text-green">
          <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </div>
        <h3 class="accent text-lg text-green mb-2 uppercase tracking-wider" data-i18n="location.phone">Telefono</h3>
        <a href={`tel:+52${phone.replace(/\s/g, '')}`} class="text-gray text-sm hover:text-green transition-colors duration-300">
          {phone}
        </a>
      </div>

      <div class="bg-white rounded-lg p-6 text-center shadow-sm">
        <div class="w-10 h-10 mx-auto mb-4 text-green">
          <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="accent text-lg text-green mb-2 uppercase tracking-wider" data-i18n="location.hours">Horario</h3>
        <p class="text-gray text-sm italic" data-i18n="location.hours.value">Proximamente</p>
      </div>
    </div>

    <!-- Quick actions -->
    <div class="flex flex-wrap justify-center gap-4 mb-12">
      <a
        href={mapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 bg-[#4285F4] text-white px-6 py-3 rounded hover:bg-[#3367D6] transition-colors duration-300"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z"/>
        </svg>
        <span>Google Maps</span>
      </a>
      <a
        href={`tel:+52${phone.replace(/\s/g, '')}`}
        class="flex items-center gap-2 bg-green text-white px-6 py-3 rounded hover:bg-green-dark transition-colors duration-300"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span data-i18n="cta.call">Llamar</span>
      </a>
      <a
        href={`https://wa.me/52${phone.replace(/\s/g, '')}?text=Hola%2C%20me%20gustaria%20hacer%20una%20reservacion%20en%20Eva's%20Restaurante.`}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 bg-[#25D366] text-white px-6 py-3 rounded hover:bg-[#1DA851] transition-colors duration-300"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a8 8 0 01-4.243-1.214l-.295-.175-2.462.731.731-2.462-.175-.295A8 8 0 1112 20z"/>
        </svg>
        <span>WhatsApp</span>
      </a>
    </div>
  </div>

  <!-- Full-width map with muted filter -->
  <div class="relative">
    <div class="w-full h-[400px] md:h-[500px] map-container overflow-hidden">
      <iframe
        src={`https://www.google.com/maps/embed/v1/place?key=AIzaSyDL535_jTw7_o24l7GOUtbPXT2w-4Qx28Y&q=Eva's+Restaurante,La+Paz,BCS,Mexico&zoom=16&maptype=roadmap`}
        width="100%"
        height="100%"
        style="border:0;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Eva's Restaurante location"
      ></iframe>
    </div>
    <!-- Top fade overlay to blend with section above -->
    <div class="absolute top-0 left-0 right-0 h-16 bg-gradient-to-b from-cream-dark to-transparent pointer-events-none"></div>
    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-8 bg-gradient-to-t from-cream-dark to-transparent pointer-events-none"></div>
  </div>
</section>

<style>
  .map-container {
    filter: saturate(0.6) contrast(1.05) brightness(1.05);
    transition: filter 0.5s ease;
  }
  .map-container:hover {
    filter: saturate(1) contrast(1) brightness(1);
  }
</style>
